<style>
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family:'Roboto',sans-serif;
  background:#f8f8f8;
  min-height:100vh;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  padding:20px;
}
.box {
  background:#fff;
  border-radius:16px;
  padding:48px 36px;
  text-align:center;
  max-width:480px;
  width:100%;
  box-shadow:0 8px 40px rgba(0,0,0,0.10);
  animation:fadeUp 0.5s ease;
}
@keyframes fadeUp {
  from { opacity:0; transform:translateY(20px); }
  to { opacity:1; transform:translateY(0); }
}
.icon { font-size:72px; margin-bottom:20px; }
.product-name {
  font-size:13px; font-weight:600; color:#e53935;
  text-transform:uppercase; letter-spacing:1px;
  margin-bottom:10px;
}
h1 { font-size:22px; font-weight:900; color:#1a1a1a; margin-bottom:12px; line-height:1.3; }
p { font-size:15px; color:#6b7280; line-height:1.7; margin-bottom:28px; }
.steps {
  background:#f8f8f8; border-radius:10px;
  padding:16px 20px; margin-bottom:28px; text-align:left;
}
.step {
  display:flex; align-items:center; gap:12px;
  font-size:14px; color:#374151; padding:6px 0;
}
.step-num {
  width:24px; height:24px; background:#e53935; color:#fff;
  border-radius:50%; display:flex; align-items:center;
  justify-content:center; font-size:12px; font-weight:700; flex-shrink:0;
}
.back-btn {
  display:inline-block; background:#1a1a1a; color:#fff;
  padding:12px 28px; border-radius:8px; font-size:15px;
  font-weight:700; text-decoration:none;
}
</style>
</head>
<body>
<div class="box">
  <div class="icon">✅</div>
  <div class="product-name" id="product-name"></div>
  <h1>Sifarişiniz qəbul olundu!</h1>
  <p>Operatorumuz qısa zamanda sizinlə əlaqə saxlayacaq. Zəhmət olmasa telefonunuzu yanınızda saxlayın.</p>
  <div class="steps">
    <div class="step"><div class="step-num">1</div><span>Sifariş qəbul edildi ✅</span></div>
    <div class="step"><div class="step-num">2</div><span>Operator sizinlə əlaqə saxlayır 📞</span></div>
    <div class="step"><div class="step-num">3</div><span>Məhsul evinizə çatdırılır 📦</span></div>
  </div>
  <a href="/" class="back-btn">Ana səhifəyə qayıt</a>
</div>

<script>
const SUPABASE_URL = 'https://vxlswyadvebtqfftflmt.supabase.co';
const SUPABASE_KEY = 'sb_publishable_obSRm2z3Og9RGg52ONdxIw_yKqtgVjG';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

const slug = new URLSearchParams(window.location.search).get('slug');

async function init() {
  if (!slug) return;

  // Load product name from Supabase
  const { data } = await sb.from('products').select('name, price').eq('slug', slug).single();
  if (data) {
    document.getElementById('product-name').textContent = data.name;
    document.title = data.name + ' | Sifarişiniz qəbul olundu';

    // Fire Purchase event
    fbq('track', 'Purchase', {
      content_name: data.name,
      content_ids: [slug],
      currency: 'AZN',
      value: data.price || 1
    });

    // TikTok Purchase event
    if (window.ttq) {
      ttq.track('PlaceAnOrder', {
        content_name: data.name,
        currency: 'AZN',
        value: data.price || 1
      });
    }
  }

  // Load settings pixels
  const { data: settings } = await sb.from('settings').select('*').limit(1).single();
  if (settings && settings.site_title) {
    document.title = settings.site_title + ' | Sifarişiniz qəbul olundu';
  }
}

init();
</script>
</body>
</html>
