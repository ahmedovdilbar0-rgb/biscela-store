<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sifarişiniz Uğurla Qəbul Olundu!</title>
    
    <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '1453724033211204');
    fbq('track', 'PageView');
    </script>
    
    <script>
        // Saytın yaddaşından (localStorage) məhsulun qiymətini və adını çəkirik
        // Əgər tapmasa, standart olaraq 1 AZN göndərir ki, siqnal boşa getməsin
        var productPrice = localStorage.getItem('product_price') || 1;
        var productName = localStorage.getItem('product_name') || 'Məhsul';

        fbq('track', 'Purchase', {
            content_name: productName,
            value: parseFloat(productPrice),
            currency: 'AZN'
        });
    </script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; padding: 100px 20px; background-color: #f0f2f5; color: #333; }
        .container { background: white; padding: 40px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); display: inline-block; max-width: 500px; }
        .icon { font-size: 60px; color: #28a745; margin-bottom: 20px; }
        h1 { margin: 0 0 10px; color: #1c1e21; }
        p { font-size: 18px; color: #606770; margin-bottom: 30px; }
        .btn { background-color: #0084ff; color: white; padding: 12px 30px; text-decoration: none; border-radius: 8px; font-weight: bold; transition: background 0.3s; }
        .btn:hover { background-color: #0073e6; }
    </style>
</head>
<body>
    <div class="container">
        <div class="icon">✅</div>
        <h1>Təşəkkür edirik!</h1>
        <p>Sifarişiniz qəbul olundu. Əməkdaşlarımız qısa zamanda sizinlə əlaqə saxlayacaq.</p>
        <br>
        <a href="/" class="btn">Mağazaya qayıt</a>
    </div>
</body>
</html>
